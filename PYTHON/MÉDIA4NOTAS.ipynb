     "output_type": "stream",
     "text": [
      "Digite a primeira nota: 4\n",
      "Digite a segunda nota: 5\n",
      "Digite a terceira nota: 6\n",
      "Digite a quarta nota: 7\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "A média aritmética é 5.5\n"
     ]
    }
   ],
   "source": [
    "4\n",
    "notas = []\n",
    "\n",
    "for i in ['primeira', 'segunda', 'terceira', 'quarta']:\n",
    "    nota = int(input(f'Digite a {i} nota:'))\n",
    "    notas.append(nota)\n",
    "    \n",
    "soma = 0\n",
    "\n",
    "for i in notas:\n",
    "    soma += i\n",
    "\n",
    "média = soma/4\n",
    "\n",
    "print(f'A média aritmética é {média}')"
   ]
  },
